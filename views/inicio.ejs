<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport"
        content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0, minimum-scale=1.0">
    <title>Kashly</title>
    <!-- Versión de la aplicación -->
    <meta name="app-version" content="<%= version %>">
    <!-- Favicon -->
    <link rel="icon" type="image/webp" href="./img/img-inicio/logo-trans.webp">
    <link rel="shortcut icon" type="image/webp" href="./img/img-inicio/logo-trans.webp">
    <!-- CSS Links -->
    <link rel="stylesheet" href="/css/inicio.css">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Boxicons -->
    <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">


    <!-- Flatpickr -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#4a90e2">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Kashly">
    <link rel="apple-touch-icon" href="/img/img-inicio/logo-trans.webp">

</head>

<body>
    <div class="main">
        <div class="total-container">
            <p>Total</p>
            <p class="total-number" data-raw="0">+0,00<span>Bs</span></p>
        </div>
        <div class="tipo">
            <button class="negativo active">- Bs 0,00</button>
            <button class="positivo">+ Bs 0,00</button>
        </div>
        <div class="filtros-main">
            <button>Este mes</button>
            <p>en</p>
            <button>Lista</button>
        </div>
        <div class="transacciones">
            <!-- Los pilares de categorías se llenan dinámicamente desde JS -->
        </div>
        <button class="buscar"><i class="fa-solid fa-magnifying-glass"></i> Buscar</button>
        <div class="entradas">
            <button><i class="fa-solid fa-microphone"></i></button>
            <button><i class="fa-solid fa-plus"></i></button>
        </div>
        <button class="ajustes"><i class="bx bx-cog"></i></button>

        <!-- Ajustes -->
        <div class="ajustes-container">
            <div class="titulo">
                <p>Ajustes</p>
                <button class="cerrar"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="opcion categorias">
                <i class="fa-solid fa-list-check"></i>
                <p>Categorias</p>
            </div>
            <div class="opcion etiquetas">
                <i class="fa-solid fa-tags"></i>
                <p>Etiquetas</p>
            </div>
            <div class="opcion listas">
                <i class="fa-solid fa-list"></i>
                <p>Listas</p>
            </div>
        </div>

        <!-- Entrada manual -->
        <div class="entrada-manual">
            <div class="titulo">
                <p></p>
                <button class="cerrar"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="content-entrada">
                <div class="fecha-recurrencia">
                    <button class="fecha">Hoy</button>
                    <input type="text" class="input-fecha"
                        style="position: absolute; left: -9999px; opacity: 0; pointer-events: none;">
                    <select class="recurrencia">
                        <option value="una-vez">Una vez</option>
                        <option value="diario">Diario</option>
                        <option value="semanal">Semanal</option>
                        <option value="quincenal">Quincenal</option>
                        <option value="mensual">Mensual</option>
                        <option value="bimestral">Bimestral</option>
                        <option value="trimestral">Trimestral</option>
                        <option value="cuatrimestral">Cuatrimestral</option>
                        <option value="semestral">Semestral</option>
                        <option value="anual">Anual</option>
                        <option value="bimensual">Bimensual</option>
                    </select>
                </div>
                <div class="monto">
                    <input class="descripcion" type="text" placeholder="Descripción">
                    <div class="tipo-monto-container input-wrapper">
                        <div class="tipo-monto">
                            <button class="active negativo"><i class="fa-solid fa-minus"></i></button>
                            <button class="positivo"><i class="fa-solid fa-plus"></i></button>
                        </div>
                        <span class="bs-prefix" style="display:none;">Bs</span>
                        <input class="monto-input" type="text" placeholder="Monto" inputmode="numeric" pattern="[0-9]*">
                    </div>
                </div>
                <div class="categorias">
                    <!-- Las categorías se llenan dinámicamente -->
                </div>
                <div class="etiquetas">
                    <!-- Las etiquetas se llenan dinámicamente -->
                </div>
                <button class="guardar"><i class="fa-solid fa-check"></i> Guardar</button>
            </div>
        </div>

        <!-- Buscador de transacciones -->
        <div class="buscador-transacciones">
            <div class="titulo">
                <p>Todas las transacciones</p>
                <button class="cerrar"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="search">
                <input type="text" placeholder="Buscar">
                <button class="icono-buscador"><i class="fa-solid fa-magnifying-glass"></i></button>
            </div>
            <div class="filtros">
                <button>Este mes</button>
                <button>Lista</button>
                <button>tipo</button>
            </div>
            <div class="transacciones-container">
                <div class="transaccion">
                    <div class="fecha-monto">
                        <p>10/07/2025</p>
                        <p>+ Bs 100,00</p>
                    </div>
                    <div class="descripcion">
                        <i class="fa-solid fa-circle-check"></i>
                        <div class="detalle">
                            <p class="categoria">Categoria</p>
                            <p class="descripcion">Descripción</p>
                            <p class="etiqueta">Etiqueta</p>
                        </div>
                        <div class="botones">
                            <button>editar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Categorias -->
        <div class="categorias-container">
            <div class="titulo">
                <p>Categorias</p>
                <button class="cerrar-categorias"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="agregar-categoria">
                <button class="icono-categoria"><i class="fa-solid fa-tag"></i></button>
                <button class="btn-agregar-categoria"><i class="fa-solid fa-plus"></i></button>
                <input type="text" placeholder="Agregar categoria">
            </div>
            <div class="categorias-content">
                <div class="categoria">
                    <i class="fa-solid fa-tag"></i>
                    <p>Categoria 1</p>
                </div>
                <div class="categoria">
                    <i class="fa-solid fa-tag"></i>
                    <p>Categoria 2</p>
                </div>
                <div class="categoria">
                    <i class="fa-solid fa-tag"></i>
                    <p>Categoria 3</p>
                </div>
            </div>
        </div>

        <!-- Etiquetas -->
        <div class="etiquetas-container">
            <div class="titulo">
                <p>Etiquetas</p>
                <button class="cerrar-etiquetas"><i class="fa-solid fa-xmark"></i></button>
            </div>
            <div class="agregar-etiqueta">
                <button class="hashtag"><i class="fa-solid fa-hashtag"></i></button>
                <button class="btn-agregar-etiqueta"><i class="fa-solid fa-plus"></i></button>
                <input type="text" placeholder="Agregar etiqueta">
            </div>
            <div class="etiquetas-content">
                <div class="etiqueta">
                    <p>#Etiqueta1</p>
                </div>
                <div class="etiqueta">
                    <p>#Etiqueta2</p>
                </div>
                <div class="etiqueta">
                    <p>#Etiqueta3</p>
                </div>
                <div class="etiqueta">
                    <p>#Etiqueta4</p>
                </div>
            </div>
        </div>

        <div class="overlay"></div>
        <div class="overlay2"></div>
        <div class="overlay3"></div>

        <!-- Modal de actualización -->
        <div class="update-modal" id="updateModal">
            <div class="modal-content">
                <h3><i class="fa-solid fa-download"></i> Actualización Disponible</h3>
                <p>Hay una nueva versión de Kashly disponible. ¿Deseas actualizar ahora?</p>
                <div class="version-info" id="versionInfo">
                    <strong>Versión actual:</strong> <span id="currentVersion">-</span><br>
                    <strong>Nueva versión:</strong> <span id="newVersion">-</span>
                </div>
                <div class="modal-buttons">
                    <button class="update-btn" id="updateBtn">
                        <i class="fa-solid fa-download"></i> Actualizar
                    </button>
                    <button class="cancel-btn" id="cancelBtn">
                        <i class="fa-solid fa-times"></i> Más tarde
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="notificacion-toast">Comida Mensual -10</div>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="/js/inicio.js" type="module"></script>

    <!-- Service Worker Registration -->
    <script>
        // Registrar el Service Worker optimizado
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', async () => {
                try {
                    const registration = await navigator.serviceWorker.register('/sw.js');
                    console.log('✅ Service Worker optimizado registrado:', registration);
                    
                    // Verificar si hay actualizaciones
                    registration.addEventListener('updatefound', () => {
                        const newWorker = registration.installing;
                        newWorker.addEventListener('statechange', () => {
                            if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                                console.log('🔄 Nueva versión disponible');
                                // Aquí podrías mostrar una notificación al usuario
                            }
                        });
                    });
                    
                    // Escuchar mensajes del Service Worker
                    navigator.serviceWorker.addEventListener('message', (event) => {
                        if (event.data && event.data.type === 'CACHE_UPDATED') {
                            console.log('✅ Cache actualizado automáticamente');
                        }
                    });
                    
                } catch (error) {
                        console.error('❌ Error al registrar el Service Worker:', error);
                }
            });
        }

        // Manejar cuando la app se instala
        window.addEventListener('appinstalled', () => {
            console.log('🎉 PWA instalada exitosamente');
        });

        // Función para actualizar cache manualmente
        window.updateCache = async () => {
            if ('serviceWorker' in navigator && navigator.serviceWorker.controller) {
                const messageChannel = new MessageChannel();
                
                messageChannel.port1.onmessage = (event) => {
                    if (event.data.success) {
                        console.log('✅ Cache actualizado manualmente');
                    } else {
                        console.error('❌ Error actualizando cache:', event.data.error);
                    }
                };
                
                navigator.serviceWorker.controller.postMessage(
                    { type: 'UPDATE_CACHE' },
                    [messageChannel.port2]
                );
            }
        };

        // Función para limpiar todo (desarrollo)
        window.clearCache = async () => {
            if ('caches' in window) {
                const cacheNames = await caches.keys();
                await Promise.all(cacheNames.map(name => caches.delete(name)));
                console.log('🧹 Cache limpiado');
            }

            if ('serviceWorker' in navigator) {
                const registrations = await navigator.serviceWorker.getRegistrations();
                for (let registration of registrations) {
                    await registration.unregister();
                    console.log('🗑️ Service Worker desinstalado');
                }
            }

            window.location.reload();
        };

        // Función para verificar estado del cache
        window.checkCacheStatus = async () => {
            if ('caches' in window) {
                const cacheNames = await caches.keys();
                console.log('📦 Caches disponibles:', cacheNames);
                
                for (const cacheName of cacheNames) {
                    const cache = await caches.open(cacheName);
                    const keys = await cache.keys();
                    console.log(`📁 ${cacheName}:`, keys.length, 'archivos');
                }
            }
        };

        // Función para verificar actualizaciones manualmente
        window.checkForUpdates = () => {
            if (window.checkForUpdates) {
                window.checkForUpdates();
            } else {
                console.log('⚠️ Función de verificación no disponible aún');
            }
        };

        // Función para forzar actualización
        window.forceUpdate = async () => {
            if ('serviceWorker' in navigator && navigator.serviceWorker.controller) {
                const messageChannel = new MessageChannel();
                
                messageChannel.port1.onmessage = (event) => {
                    if (event.data.success) {
                        console.log('✅ Actualización forzada completada:', event.data.result);
                        window.location.reload();
                    } else {
                        console.error('❌ Error en actualización forzada:', event.data.error);
                    }
                };
                
                navigator.serviceWorker.controller.postMessage(
                    { type: 'UPDATE_FROM_VERCEL' },
                    [messageChannel.port2]
                );
            }
        };

        // Función para obtener versión del cache
        window.getCacheVersion = async () => {
            console.log('🔍 Obteniendo versión del cache...');
            if ('caches' in window) {
                try {
                    const cachedResponse = await caches.match('/');
                    if (cachedResponse) {
                        const text = await cachedResponse.text();
                        const metaMatch = text.match(/<meta name="app-version" content="([^"]+)"/i);
                        if (metaMatch) {
                            console.log('📱 Versión en cache:', metaMatch[1]);
                            return metaMatch[1];
                        } else {
                            console.log('⚠️ No se encontró versión en el cache');
                            return null;
                        }
                    } else {
                        console.log('⚠️ No hay cache de la página principal');
                        return null;
                    }
                } catch (error) {
                    console.error('❌ Error obteniendo versión del cache:', error);
                    return null;
                }
            } else {
                console.log('⚠️ Cache API no disponible');
                return null;
            }
        };

        // Función para obtener versión del servidor
        window.getServerVersion = async () => {
            console.log('🌐 Obteniendo versión del servidor...');
            try {
                const response = await fetch('/api/version?t=' + Date.now());
                if (response.ok) {
                    const data = await response.json();
                    console.log('📋 Versión del servidor:', data.version);
                    return data.version;
                } else {
                    console.log('❌ Error obteniendo versión del servidor:', response.status);
                    return null;
                }
            } catch (error) {
                console.error('❌ Error en getServerVersion:', error);
                return null;
            }
        };

        // Función para verificar versión desde ajustes
        window.checkVersionFromSettings = () => {
            console.log('🔍 Verificando versión desde ajustes...');
            const ajustesBtn = document.querySelector('.ajustes');
            if (ajustesBtn) {
                ajustesBtn.click();
                setTimeout(() => {
                    console.log('✅ Ajustes abiertos, verificación iniciada');
                }, 100);
            } else {
                console.log('❌ Botón de ajustes no encontrado');
            }
        };

        // Función para simular apertura de ajustes sin verificación
        window.openSettingsOnly = () => {
            console.log('🔧 Abriendo ajustes (solo visualización)...');
            const ajustesBtn = document.querySelector('.ajustes');
            if (ajustesBtn) {
                ajustesBtn.click();
                console.log('✅ Ajustes abiertos - solo muestra versión actual');
            } else {
                console.log('❌ Botón de ajustes no encontrado');
            }
        };

        // Función para limpiar cache y forzar verificación
        window.forceVersionCheck = async () => {
            console.log('🧹 Limpiando cache y forzando verificación...');
            if ('caches' in window) {
                try {
                    const cacheNames = await caches.keys();
                    console.log('📦 Caches encontrados:', cacheNames);
                    
                    const mainCache = cacheNames.find(name => name.startsWith('kashly-v'));
                    if (mainCache) {
                        await caches.delete(mainCache);
                        console.log('🗑️ Cache eliminado:', mainCache);
                    }
                    
                    window.location.reload();
                } catch (error) {
                    console.error('❌ Error limpiando cache:', error);
                }
            } else {
                console.log('⚠️ Cache API no disponible');
            }
        };

        // Función para verificar versión inmediatamente
        window.checkVersionNow = () => {
            console.log('🔍 Verificación inmediata de versión...');
            checkForUpdates();
        };

        // Función para verificar estado del cache
        window.checkCacheStatus = async () => {
            console.log('🔍 Verificando estado del cache...');
            
            const cacheVersion = await getCacheVersion();
            const serverVersion = await getServerVersion();
            
            console.log('📊 Estado actual:');
            console.log('📱 Cache:', cacheVersion);
            console.log('🌐 Servidor:', serverVersion);
            console.log('🔄 ¿Hay diferencia?', cacheVersion !== serverVersion);
            
            if (cacheVersion === serverVersion) {
                console.log('✅ Cache actualizado correctamente');
            } else {
                console.log('⚠️ Cache necesita actualización');
            }
        };

        // Función para verificar después de actualizar
        window.checkAfterUpdate = async () => {
            console.log('🔍 Verificando después de actualizar...');
            
            // Esperar un poco para que se complete la actualización
            setTimeout(async () => {
                const cacheVersion = await getCacheVersion();
                const serverVersion = await getServerVersion();
                
                console.log('📊 Estado después de actualizar:');
                console.log('📱 Cache:', cacheVersion);
                console.log('🌐 Servidor:', serverVersion);
                
                if (cacheVersion === serverVersion) {
                    console.log('✅ Actualización exitosa - versiones coinciden');
                } else {
                    console.log('❌ Error en actualización - versiones diferentes');
                    console.log('💡 Probablemente el cache no se actualizó correctamente');
                }
            }, 2000);
        };

        // Función para forzar actualización completa
        window.forceCompleteUpdate = async () => {
            console.log('🔄 Forzando actualización completa...');
            
            // Limpiar cache primero
            if ('caches' in window) {
                try {
                    const cacheNames = await caches.keys();
                    console.log('📦 Caches encontrados:', cacheNames);
                    
                    for (const cacheName of cacheNames) {
                        await caches.delete(cacheName);
                        console.log('🗑️ Cache eliminado:', cacheName);
                    }
                    
                    console.log('✅ Todos los caches eliminados');
                    
                    // Recargar página para forzar nueva instalación
                    window.location.reload(true);
                } catch (error) {
                    console.error('❌ Error limpiando caches:', error);
                }
            } else {
                console.log('⚠️ Cache API no disponible');
            }
        };

        // Función para verificar estado del servidor
        window.checkServerStatus = async () => {
            console.log('🔍 Verificando estado del servidor...');
            
            try {
                const response = await fetch('/api/version?t=' + Date.now());
                if (response.ok) {
                    const data = await response.json();
                    console.log('📋 Versión del servidor:', data.version);
                    
                    // Verificar también el HTML
                    const htmlResponse = await fetch('/?t=' + Date.now());
                    if (htmlResponse.ok) {
                        const html = await htmlResponse.text();
                        const metaMatch = html.match(/<meta name="app-version" content="([^"]+)"/i);
                        if (metaMatch) {
                            console.log('📄 Versión en HTML:', metaMatch[1]);
                            console.log('🔄 ¿Coinciden?', data.version === metaMatch[1]);
                        }
                    }
                } else {
                    console.log('❌ Error obteniendo versión del servidor:', response.status);
                }
            } catch (error) {
                console.error('❌ Error verificando servidor:', error);
            }
        };
    </script>
</body>

</html>